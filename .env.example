# Server Configuration
CONGRAPH_PORT=3000
CONGRAPH_HOST=0.0.0.0
CONGRAPH_LOG_LEVEL=info

# Database Configuration
CONGRAPH_DB_PATH=./data/congraphdb
CONGRAPH_DB_IN_MEMORY=false
CONGRAPH_DB_BUFFER_SIZE=0
CONGRAPH_DB_COMPRESSION=true
CONGRAPH_DB_READ_ONLY=false
CONGRAPH_DB_MAX_SIZE=

# Authentication
CONGRAPH_AUTH_ENABLED=true
CONGRAPH_JWT_SECRET=your-secret-key-change-me-in-production
CONGRAPH_JWT_EXPIRES_IN=24h
CONGRAPH_API_KEY=your-api-key-here

# Rate Limiting
CONGRAPH_RATE_LIMIT_ENABLED=true
CONGRAPH_RATE_LIMIT_MAX=100
CONGRAPH_RATE_LIMIT_WINDOW=60000

# Backup Configuration
CONGRAPH_BACKUP_ENABLED=true
CONGRAPH_BACKUP_INTERVAL=300000
CONGRAPH_BACKUP_RETENTION=10
CONGRAPH_BACKUP_PATH=./backups
CONGRAPH_BACKUP_COMPRESSION=true

# CORS
CONGRAPH_CORS_ORIGIN=*

# Environment
NODE_ENV=production
